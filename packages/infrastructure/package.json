{
	"name": "@nextnode-solutions/infrastructure",
	"version": "0.0.0-development",
	"description": "NextNode infrastructure CLI — deploy to VPS, Cloudflare Pages, or serverless targets",
	"keywords": [
		"cli",
		"deploy",
		"infrastructure",
		"nextnode"
	],
	"homepage": "https://github.com/NextNodeSolutions/core#readme",
	"license": "MIT",
	"author": "NextNode Solutions",
	"repository": {
		"type": "git",
		"url": "https://github.com/NextNodeSolutions/core.git",
		"directory": "packages/infrastructure"
	},
	"bin": {
		"infra": "./dist/index.js"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts --clean",
		"dev": "node src/index.ts",
		"format": "oxfmt --write .",
		"format:check": "oxfmt --check .",
		"lint": "oxlint",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@nextnode-solutions/logger": "^1.0.0",
		"smol-toml": "^1.6.1"
	},
	"devDependencies": {
		"@nextnode-solutions/standards": "workspace:*",
		"oxfmt": "^0.28.0",
		"oxlint": "^1.43.0",
		"tsup": "^8.0.0",
		"typescript": "^6",
		"vitest": "^3.0.0"
	},
	"engines": {
		"node": ">=24.0.0"
	},
	"packageManager": "pnpm@10.11.0"
}
