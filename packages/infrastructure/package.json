{
  "name": "@nextnode-solutions/infrastructure",
  "version": "0.0.0-development",
  "description": "NextNode infrastructure CLI — deploy to VPS, Cloudflare Pages, or serverless targets",
  "keywords": [
    "cli",
    "deploy",
    "infrastructure",
    "nextnode"
  ],
  "homepage": "https://github.com/NextNodeSolutions/core#readme",
  "license": "MIT",
  "author": "NextNode Solutions",
  "files": [
    "dist"
  ],
  "bin": {
    "infra": "./dist/index.js"
  },
  "repository": {
    "directory": "packages/infrastructure",
    "type": "git",
    "url": "https://github.com/NextNodeSolutions/core.git"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean",
    "dev": "node src/index.ts",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsgo --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1030.0",
    "@nextnode-solutions/logger": "^1.0.0",
    "smol-toml": "^1.6.1",
    "ssh2": "^1.17.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@nextnode-solutions/standards": "workspace:*",
    "@types/ssh2": "^1.15.5",
    "@typescript/native-preview": "7.0.0-dev.20260407.1",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "tsup": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.11.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./config/types": {
      "types": "./src/config/types.ts"
    }
  }
}
