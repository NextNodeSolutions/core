{
  "name": "@nextnode-solutions/monitoring",
  "version": "0.0.0-development",
  "description": "NextNode monitoring service — multi-tenant uptime probes, log ingest, SLO-driven alerting",
  "keywords": [
    "alerting",
    "logs",
    "monitoring",
    "nextnode",
    "slo",
    "uptime"
  ],
  "homepage": "https://github.com/NextNodeSolutions/core#readme",
  "license": "MIT",
  "author": "NextNode Solutions",
  "files": [
    "dist"
  ],
  "bin": {
    "nn-monitor": "./dist/index.js"
  },
  "repository": {
    "directory": "packages/monitoring",
    "type": "git",
    "url": "https://github.com/NextNodeSolutions/core.git"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean",
    "dev": "node src/index.ts",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "type-check": "tsgo --noEmit"
  },
  "dependencies": {
    "@nextnode-solutions/logger": "workspace:*",
    "smol-toml": "^1.6.1"
  },
  "devDependencies": {
    "@nextnode-solutions/standards": "workspace:*",
    "@types/node": "^22",
    "@typescript/native-preview": "7.0.0-dev.20260407.1",
    "@vitest/coverage-v8": "^3",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "tsup": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  }
}
