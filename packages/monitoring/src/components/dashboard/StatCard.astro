---
import type { Tone } from '@/lib/domain/badge-status.ts'

interface Props {
	label: string
	value: string | number
	hint?: string
	tone?: Tone
	class?: string
}

const {
	label,
	value,
	hint,
	tone = 'neutral',
	class: className = '',
} = Astro.props

const toneValueClass: Record<Tone, string> = {
	neutral: 'text-base-900',
	positive: 'text-accent-800',
	warning: 'text-amber-700',
	danger: 'text-red-700',
}
---

<article
	class:list={[
		'rounded-2xl border border-base-100 bg-white p-5 shadow-subtle',
		className,
	]}
>
	<p class="font-mono text-[10px] uppercase tracking-wider text-base-500">
		{label}
	</p>
	<p
		class:list={[
			'mt-3 truncate font-display text-2xl font-semibold tracking-tight',
			toneValueClass[tone],
		]}
		title={String(value)}
	>
		{value}
	</p>
	{hint && <p class="mt-1 text-xs text-base-500">{hint}</p>}
</article>
