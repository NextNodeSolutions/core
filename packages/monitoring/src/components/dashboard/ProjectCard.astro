---
import StatusBadge from '@/components/dashboard/StatusBadge.astro'
import type { ProjectSummary } from '@/lib/domain/project.ts'

interface Props {
	project: ProjectSummary
}

const { project } = Astro.props

const TARGET_LABEL: Record<ProjectSummary['target'], string> = {
	hetzner: 'Hetzner VPS',
	'cloudflare-pages': 'Cloudflare Pages',
}
---

<article
	class="group flex flex-col gap-5 rounded-2xl border border-base-100 bg-white p-6 shadow-subtle transition-colors hover:border-base-200"
>
	<header class="flex items-start justify-between gap-4">
		<div class="min-w-0">
			<h3 class="font-display text-lg font-semibold text-base-900 truncate">
				{project.name}
			</h3>
			<p class="mt-1 font-mono text-xs text-base-500 truncate">
				{project.repo}
			</p>
		</div>
		<StatusBadge status={project.status} />
	</header>

	<dl class="grid grid-cols-3 gap-3 text-xs">
		<div>
			<dt class="font-mono text-[10px] uppercase tracking-wider text-base-500">
				Target
			</dt>
			<dd class="mt-1 text-base-900">{TARGET_LABEL[project.target]}</dd>
		</div>
		<div>
			<dt class="font-mono text-[10px] uppercase tracking-wider text-base-500">
				Env
			</dt>
			<dd class="mt-1 text-base-900 capitalize">{project.environment}</dd>
		</div>
		<div>
			<dt class="font-mono text-[10px] uppercase tracking-wider text-base-500">
				Last deploy
			</dt>
			<dd class="mt-1 font-mono text-base-900 truncate">
				{project.lastDeployAt ?? '—'}
			</dd>
		</div>
	</dl>

	<footer class="flex items-center justify-between border-t border-base-100 pt-4">
		<a
			href={`/projects/${project.slug}`}
			class="inline-flex items-center gap-1 text-sm font-medium text-base-900 transition-colors hover:text-accent-700"
		>
			Open project
			<span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">→</span>
		</a>
		<code class="font-mono text-[11px] text-base-400">{project.slug}</code>
	</footer>
</article>
