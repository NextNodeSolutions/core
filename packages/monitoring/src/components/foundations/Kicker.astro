---
interface Props {
	class?: string
}

const { class: className = '' } = Astro.props
---

<div class:list={['flex items-center gap-x-2', className]}>
	<div aria-hidden="true" class="pointer-events-none size-3 bg-base-900"></div>
	<p class="font-mono text-xs uppercase tracking-wide text-base-900">
		<slot />
	</p>
</div>
