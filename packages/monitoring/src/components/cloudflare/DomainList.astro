---
import DomainItem from '@/components/cloudflare/DomainItem.astro'
import Button from '@/components/foundations/Button.astro'
import SectionHeader from '@/components/dashboard/SectionHeader.astro'
import type { CloudflarePagesDomain } from '@/lib/domain/cloudflare/pages-domain.ts'
import { cloudflareApiPath } from '@/lib/domain/cloudflare/pages-routes.ts'

interface Props {
	projectName: string
	domains: ReadonlyArray<CloudflarePagesDomain>
}

const { projectName, domains } = Astro.props
---

<section class="mt-10 space-y-6">
	<SectionHeader
		kicker="Domains"
		title="Custom domains"
		description="Attach a custom domain to this Pages project and manage its verification status."
	/>
	<div class="rounded-2xl border border-base-100 bg-white p-6 shadow-subtle">
		<form
			method="post"
			action={cloudflareApiPath(projectName, 'domains')}
			class="flex flex-col gap-3 border-b border-base-100 pb-6 sm:flex-row sm:items-end"
		>
			<label class="flex min-w-0 flex-1 flex-col gap-1 text-xs text-base-600">
				<span
					class="font-mono uppercase tracking-wider text-[10px] text-base-500"
				>
					Add domain
				</span>
				<input
					name="domain"
					type="text"
					placeholder="www.example.com"
					required
					class="h-9 rounded-md border border-base-200 bg-white px-3 font-mono text-xs text-base-900 focus:border-base-900 focus:outline-2 focus:outline-offset-2 focus:outline-base-900"
				/>
			</label>
			<Button size="sm" variant="default" type="submit">Attach domain</Button>
		</form>

		{
			domains.length === 0 ? (
				<p class="mt-6 font-mono text-xs text-base-500 italic">
					No custom domain attached yet.
				</p>
			) : (
				<ul class="mt-4 divide-y divide-base-100">
					{domains.map(domain => (
						<DomainItem projectName={projectName} domain={domain} />
					))}
				</ul>
			)
		}
	</div>
</section>
