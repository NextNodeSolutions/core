---
import StatCard from '@/components/dashboard/StatCard.astro'
import { badgeStatusToTone } from '@/lib/domain/badge-status.ts'
import type { Health } from '@/lib/domain/badge-status.ts'
import type { CloudflarePagesDeployment } from '@/lib/domain/cloudflare/pages-deployment.ts'
import type { CloudflarePagesProject } from '@/lib/domain/cloudflare/pages-project.ts'
import { formatRelativeTime } from '@/lib/domain/relative-time.ts'

interface Props {
	project: CloudflarePagesProject
	health: Health
	deployments: ReadonlyArray<CloudflarePagesDeployment>
	nowMs: number
}

const { project, health, deployments, nowMs } = Astro.props

const lastProductionDeploy =
	deployments.find(deployment => deployment.environment === 'production') ??
	null
---

<section class="mt-10 grid grid-cols-2 gap-4 lg:grid-cols-4">
	<StatCard
		label="Status"
		value={health.label}
		tone={badgeStatusToTone[health.status]}
	/>
	<StatCard
		label="Last prod deploy"
		value={
			lastProductionDeploy
				? formatRelativeTime(lastProductionDeploy.createdAt, nowMs)
				: '—'
		}
		hint={lastProductionDeploy?.shortId}
	/>
	<StatCard label="Branch" value={project.productionBranch} />
	<StatCard label="Age" value={formatRelativeTime(project.createdAt, nowMs)} />
</section>
