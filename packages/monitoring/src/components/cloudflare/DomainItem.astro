---
import Button from '@/components/foundations/Button.astro'
import StatusBadge from '@/components/dashboard/StatusBadge.astro'
import { DOMAIN_BADGE_STATUS } from '@/lib/domain/cloudflare/pages-domain.ts'
import type { CloudflarePagesDomain } from '@/lib/domain/cloudflare/pages-domain.ts'
import { cloudflareApiPath } from '@/lib/domain/cloudflare/pages-routes.ts'
import { formatIsoDate } from '@/lib/domain/relative-time.ts'

interface Props {
	projectName: string
	domain: CloudflarePagesDomain
}

const { projectName, domain } = Astro.props

const removeConfirmation = `Remove ${domain.name} from this project?`
---

<li class="flex flex-col gap-3 py-3 sm:flex-row sm:items-center sm:gap-4">
	<div class="flex min-w-0 flex-1 items-center gap-3">
		<StatusBadge
			status={DOMAIN_BADGE_STATUS[domain.status]}
			label={domain.status}
		/>
		<div class="min-w-0">
			<p class="truncate font-mono text-sm text-accent-800">{domain.name}</p>
			<p class="mt-0.5 font-mono text-[10px] text-base-500">
				{domain.certificateAuthority ?? 'no certificate'}
				{' · '}
				{formatIsoDate(domain.createdAt)}
			</p>
			{
				domain.verificationData && (
					<p class="mt-1 text-xs text-red-700">{domain.verificationData}</p>
				)
			}
		</div>
	</div>
	<div class="flex shrink-0 items-center gap-2">
		<form
			method="post"
			action={cloudflareApiPath(projectName, 'domains', domain.name, 'verify')}
		>
			<Button size="xs" variant="muted" type="submit">Re-check DNS</Button>
		</form>
		<form
			method="post"
			action={cloudflareApiPath(projectName, 'domains', domain.name)}
			onsubmit={`return confirm(${JSON.stringify(removeConfirmation)})`}
		>
			<input type="hidden" name="_method" value="delete" />
			<Button size="xs" variant="danger" type="submit">Remove</Button>
		</form>
	</div>
</li>
