---
import Button from '@/components/foundations/Button.astro'
import type { ButtonVariant } from '@/components/foundations/Button.astro'
import SectionHeader from '@/components/dashboard/SectionHeader.astro'
import type { CloudflarePagesEnvironment } from '@/lib/domain/cloudflare/pages-environment.ts'
import { cloudflareApiPath } from '@/lib/domain/cloudflare/pages-routes.ts'

interface Props {
	projectName: string
	environment: CloudflarePagesEnvironment
	productionBranch: string | null
}

const { projectName, environment, productionBranch } = Astro.props

const branchDescription =
	environment === 'production'
		? (productionBranch ?? 'the production branch')
		: 'the development branch'

const deleteConfirmation = `Delete Cloudflare Pages project "${projectName}"? This removes every deployment and custom domain attached to it.`

interface Action {
	readonly title: string
	readonly description: string
	readonly action: string
	readonly label: string
	readonly variant: ButtonVariant
	readonly confirmation?: string
	readonly methodOverride?: 'delete'
	readonly hiddenFields?: ReadonlyArray<{ name: string; value: string }>
}

const actions: ReadonlyArray<Action> = [
	{
		title: 'Trigger deployment',
		description: `Start a new build of ${branchDescription}.`,
		action: cloudflareApiPath(projectName, 'deployments'),
		label: 'Trigger deployment',
		variant: 'default',
		hiddenFields: [{ name: 'environment', value: environment }],
	},
	{
		title: 'Purge edge cache',
		description: 'Invalidate cached assets on every Cloudflare PoP.',
		action: cloudflareApiPath(projectName, 'purge-cache'),
		label: 'Purge cache',
		variant: 'accent',
	},
	{
		title: 'Delete project',
		description: 'Permanent. Removes all deployments, domains, and env vars.',
		action: cloudflareApiPath(projectName),
		label: 'Delete project',
		variant: 'danger',
		confirmation: deleteConfirmation,
		methodOverride: 'delete',
	},
]
---

<section class="mt-10 space-y-6">
	<SectionHeader
		kicker="Actions"
		title="Project controls"
		description="Trigger a deployment, purge the edge cache, or delete the project. Destructive actions require confirmation."
	/>
	<div class="grid grid-cols-1 gap-4 md:grid-cols-3">
		{
			actions.map(action => (
				<form
					method="post"
					action={action.action}
					onsubmit={
						action.confirmation
							? `return confirm(${JSON.stringify(action.confirmation)})`
							: undefined
					}
					class="flex flex-col gap-4 rounded-2xl border border-base-100 bg-white p-5 shadow-subtle"
				>
					{action.methodOverride && (
						<input
							type="hidden"
							name="_method"
							value={action.methodOverride}
						/>
					)}
					{action.hiddenFields?.map(field => (
						<input type="hidden" name={field.name} value={field.value} />
					))}
					<div class="flex-1">
						<p class="font-display text-sm font-semibold text-base-900">
							{action.title}
						</p>
						<p class="mt-1 text-xs text-base-500">{action.description}</p>
					</div>
					<Button
						size="sm"
						variant={action.variant}
						type="submit"
						class="w-full"
					>
						{action.label}
					</Button>
				</form>
			))
		}
	</div>
</section>
