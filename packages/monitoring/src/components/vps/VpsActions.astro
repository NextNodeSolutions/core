---
import SectionHeader from '@/components/dashboard/SectionHeader.astro'
import Button from '@/components/foundations/Button.astro'
import {
	METHOD_OVERRIDE_DELETE,
	METHOD_OVERRIDE_FIELD,
} from '@/lib/adapters/method-override-route.ts'
import { vpsApiPath } from '@/lib/domain/hetzner/vps-routes.ts'

interface Props {
	serverName: string
}

const { serverName } = Astro.props

const destroyConfirmation = `Destroy VPS "${serverName}"? Every project running on this host will be torn down and the Hetzner server will be permanently deleted. This cannot be undone.`
---

<section class="mt-10 space-y-6">
	<SectionHeader
		kicker="Host actions"
		title="VPS lifecycle"
		description="Host-level controls only. Project-level actions (deploy, teardown app, env vars) live on the project view."
	/>
	<div class="grid grid-cols-1 gap-4 md:grid-cols-2">
		<form
			method="post"
			action={vpsApiPath(serverName)}
			onsubmit={`return confirm(${JSON.stringify(destroyConfirmation)})`}
			class="flex flex-col gap-4 rounded-2xl border border-base-100 bg-white p-5 shadow-subtle"
		>
			<input
				type="hidden"
				name={METHOD_OVERRIDE_FIELD}
				value={METHOD_OVERRIDE_DELETE}
			/>
			<div class="flex-1">
				<p class="font-display text-sm font-semibold text-base-900">
					Destroy VPS
				</p>
				<p class="mt-1 text-xs text-base-500">
					Permanently delete the Hetzner server. Tears down every project running on it.
				</p>
			</div>
			<Button size="sm" variant="danger" type="submit" class="w-full">
				Destroy VPS
			</Button>
		</form>
	</div>
</section>
