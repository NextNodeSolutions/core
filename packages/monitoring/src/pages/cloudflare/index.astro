---
import DashboardLayout from '@/layouts/DashboardLayout.astro'
import SectionHeader from '@/components/dashboard/SectionHeader.astro'

export const prerender = false
---

<DashboardLayout
	title="Cloudflare"
	breadcrumbs={[{ label: 'Infrastructure' }, { label: 'Cloudflare' }]}
>
	<SectionHeader
		kicker="Cloudflare"
		title="Cloudflare projects"
		description="Pages deployments and Workers stats surfaced via wrangler."
	/>

	<div class="mt-8 rounded-2xl border border-dashed border-base-200 bg-white p-10 text-center">
		<p class="font-mono text-xs text-base-500">Wrangler bridge pending.</p>
	</div>
</DashboardLayout>
