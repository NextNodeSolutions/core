---
import CloudflareFleetSection from '@/components/cloudflare/CloudflareFleetSection.astro'
import SectionHeader from '@/components/dashboard/SectionHeader.astro'
import Skeleton from '@/components/dashboard/Skeleton.astro'
import DashboardLayout from '@/layouts/DashboardLayout.astro'

export const prerender = false
---

<DashboardLayout
	title="Cloudflare"
	breadcrumbs={[{ label: 'Infrastructure' }, { label: 'Cloudflare' }]}
>
	<SectionHeader
		kicker="Cloudflare"
		title="Cloudflare Pages projects"
		description="Logical projects grouped by base name. Each card shows the production project (`name`) and its development counterpart (`name-dev`) when both exist."
	/>

	<CloudflareFleetSection server:defer>
		<Skeleton slot="fallback" rows={5} class="mt-8" />
	</CloudflareFleetSection>
</DashboardLayout>
