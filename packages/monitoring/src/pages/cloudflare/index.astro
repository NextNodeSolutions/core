---
import EmptyListMessage from '@/components/dashboard/EmptyListMessage.astro'
import LoadStateBanner from '@/components/dashboard/LoadStateBanner.astro'
import SectionHeader from '@/components/dashboard/SectionHeader.astro'
import DashboardLayout from '@/layouts/DashboardLayout.astro'
import { resolveAccountId } from '@/lib/adapters/cloudflare/accounts.ts'
import { listPagesProjects } from '@/lib/adapters/cloudflare/pages-projects.ts'
import { ENV_KEYS, getEnv, requireEnv } from '@/lib/adapters/env.ts'
import { loadPageState } from '@/lib/adapters/load-page-state.ts'

export const prerender = false

const state = await loadPageState('cloudflare.projects.page', async () => {
	const token = requireEnv(ENV_KEYS.CLOUDFLARE_API_TOKEN)
	const accountId =
		getEnv(ENV_KEYS.CLOUDFLARE_ACCOUNT_ID) ?? (await resolveAccountId(token))
	return listPagesProjects(accountId, token)
})
---

<DashboardLayout
	title="Cloudflare"
	breadcrumbs={[{ label: 'Infrastructure' }, { label: 'Cloudflare' }]}
>
	<SectionHeader
		kicker="Cloudflare"
		title="Cloudflare Pages projects"
		description="Every Pages project reachable with the current API token."
	/>

	{
		state.kind === 'ok' && state.data.length > 0 && (
			<ul class="mt-8 divide-y divide-base-100 overflow-hidden rounded-2xl border border-base-100 bg-white shadow-subtle">
				{state.data.map((project) => (
					<li class="flex flex-wrap items-center gap-4 px-6 py-5">
						<div class="min-w-0 flex-1">
							<h3 class="font-display text-base font-semibold text-base-900">
								{project.name}
							</h3>
							<p class="mt-1 font-mono text-xs text-base-500 truncate">
								{project.subdomain}
							</p>
						</div>

						<dl class="flex items-center gap-6 text-xs">
							<div>
								<dt class="font-mono text-[10px] uppercase tracking-wider text-base-500">
									Prod branch
								</dt>
								<dd class="mt-1 font-mono text-base-900">
									{project.productionBranch}
								</dd>
							</div>
							<div>
								<dt class="font-mono text-[10px] uppercase tracking-wider text-base-500">
									Domains
								</dt>
								<dd class="mt-1 font-mono text-base-900">
									{project.domains.length}
								</dd>
							</div>
							<div>
								<dt class="font-mono text-[10px] uppercase tracking-wider text-base-500">
									Created
								</dt>
								<dd class="mt-1 font-mono text-base-900">
									{project.createdAt.slice(0, 10)}
								</dd>
							</div>
						</dl>
					</li>
				))}
			</ul>
		)
	}

	{
		state.kind === 'ok' && state.data.length === 0 && (
			<EmptyListMessage message="No Pages project found in this account." />
		)
	}

	<LoadStateBanner state={state} upstreamLabel="Cloudflare API error" />
</DashboardLayout>
