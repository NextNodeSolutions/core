---
import DeploymentList from '@/components/cloudflare/DeploymentList.astro'
import DeploymentTail from '@/components/cloudflare/DeploymentTail.astro'
import ProjectActions from '@/components/cloudflare/ProjectActions.astro'
import ProjectHeader from '@/components/cloudflare/ProjectHeader.astro'
import ProjectStatsGrid from '@/components/cloudflare/ProjectStatsGrid.astro'
import LoadStateBanner from '@/components/dashboard/LoadStateBanner.astro'
import DashboardLayout from '@/layouts/DashboardLayout.astro'
import { resolveCloudflareClient } from '@/lib/adapters/cloudflare/accounts.ts'
import { listPagesDeployments } from '@/lib/adapters/cloudflare/pages-deployments.ts'
import { getPagesProject } from '@/lib/adapters/cloudflare/pages-projects.ts'
import { loadPageState } from '@/lib/adapters/load-page-state.ts'
import { findRollbackCandidate } from '@/lib/domain/cloudflare/pages-deployment.ts'
import { resolveProjectIdentity } from '@/lib/domain/cloudflare/pages-environment.ts'
import { computeProjectHealth } from '@/lib/domain/cloudflare/pages-project-health.ts'
import { buildCloudflareDashboardUrl } from '@/lib/domain/cloudflare/pages-routes.ts'

const RECENT_DEPLOYMENTS_LIMIT = 20

export const prerender = false

const { name } = Astro.params

if (!name) {
	return Astro.redirect('/cloudflare')
}

const identity = resolveProjectIdentity(name)

const state = await loadPageState(`cloudflare.projects.${name}.page`, async () => {
	const client = await resolveCloudflareClient()
	const [project, deployments] = await Promise.all([
		getPagesProject({ client, projectName: name }),
		listPagesDeployments({
			client,
			projectName: name,
			limit: RECENT_DEPLOYMENTS_LIMIT,
		}),
	])
	return { accountId: client.accountId, project, deployments }
})

const data = state.kind === 'ok' ? state.data : null
const project = data?.project ?? null
const deployments = data?.deployments ?? []

const health = computeProjectHealth(deployments)
const rollbackCandidate = findRollbackCandidate(deployments)
const latestDeployment = deployments[0] ?? null

const dashboardUrl = data
	? buildCloudflareDashboardUrl(data.accountId, name)
	: null
const nowMs = Date.now()
---

<DashboardLayout
	title={`Cloudflare · ${name}`}
	breadcrumbs={[
		{ label: 'Infrastructure' },
		{ label: 'Cloudflare', href: '/cloudflare' },
		{ label: name },
	]}
>
	<ProjectHeader
		name={name}
		environment={identity.environment}
		subdomain={project?.subdomain ?? null}
		dashboardUrl={dashboardUrl}
		health={health}
	/>

	{
		project && (
			<ProjectStatsGrid
				project={project}
				health={health}
				deployments={deployments}
				nowMs={nowMs}
			/>
		)
	}

	<ProjectActions
		projectName={name}
		environment={identity.environment}
		productionBranch={project?.productionBranch ?? null}
	/>

	<DeploymentTail projectName={name} deployment={latestDeployment} />

	<DeploymentList
		projectName={name}
		deployments={deployments}
		rollbackCandidateId={rollbackCandidate?.id ?? null}
		nowMs={nowMs}
	/>

	<LoadStateBanner state={state} upstreamLabel="Cloudflare API error" />
</DashboardLayout>
