---
import HomeCloudflareSection from '@/components/dashboard/HomeCloudflareSection.astro'
import HomeHetznerSection from '@/components/dashboard/HomeHetznerSection.astro'
import SectionHeader from '@/components/dashboard/SectionHeader.astro'
import Skeleton from '@/components/dashboard/Skeleton.astro'
import DashboardLayout from '@/layouts/DashboardLayout.astro'

export const prerender = false
---

<DashboardLayout title="Dashboard" breadcrumbs={[{ label: 'Overview' }]}>
	<section class="space-y-8">
		<SectionHeader
			kicker="Control plane"
			title="NextNode control plane"
			description="Live view of the Hetzner fleet and Cloudflare Pages projects managed by this account."
		/>
	</section>

	<div class="mt-14">
		<HomeHetznerSection server:defer>
			<Skeleton slot="fallback" rows={3} withStats />
		</HomeHetznerSection>
	</div>

	<div class="mt-14">
		<HomeCloudflareSection server:defer>
			<Skeleton slot="fallback" rows={4} />
		</HomeCloudflareSection>
	</div>
</DashboardLayout>
