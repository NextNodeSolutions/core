---
import SectionHeader from '@/components/dashboard/SectionHeader.astro'
import Skeleton from '@/components/dashboard/Skeleton.astro'
import VpsFleetSection from '@/components/vps/VpsFleetSection.astro'
import DashboardLayout from '@/layouts/DashboardLayout.astro'

export const prerender = false
---

<DashboardLayout
	title="VPS"
	breadcrumbs={[{ label: 'Infrastructure' }, { label: 'VPS fleet' }]}
>
	<SectionHeader
		kicker="Infrastructure"
		title="Hetzner VPS fleet"
		description="Every Hetzner server reachable with the current API token. All traffic reaches these hosts through Tailscale."
	/>

	<VpsFleetSection server:defer>
		<Skeleton slot="fallback" rows={5} class="mt-8" />
	</VpsFleetSection>
</DashboardLayout>
