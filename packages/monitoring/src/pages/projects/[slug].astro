---
import DashboardLayout from '@/layouts/DashboardLayout.astro'
import Button from '@/components/foundations/Button.astro'
import StatusBadge from '@/components/dashboard/StatusBadge.astro'
import SectionHeader from '@/components/dashboard/SectionHeader.astro'
import StatCard from '@/components/dashboard/StatCard.astro'

export const prerender = false

const { slug } = Astro.params

if (!slug) {
	return Astro.redirect('/')
}
---

<DashboardLayout
	title={`Project · ${slug}`}
	breadcrumbs={[
		{ label: 'Projects', href: '/' },
		{ label: slug },
	]}
>
	<header class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
		<div>
			<p class="font-mono text-[10px] uppercase tracking-wider text-base-500">
				Project
			</p>
			<h1 class="mt-2 font-display text-3xl font-semibold tracking-tight text-base-900">
				{slug}
			</h1>
		</div>
		<StatusBadge status="unknown" />
	</header>

	<section class="mt-10 space-y-6">
		<SectionHeader kicker="Actions" title="Workflow control" />
		<div class="rounded-2xl border border-base-100 bg-white p-6 shadow-subtle">
			<div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
				<form
					method="post"
					action={`/api/projects/${slug}/workflows/dispatch`}
					class="space-y-3"
				>
					<div class="grid grid-cols-2 gap-3">
						<label class="flex flex-col gap-1 text-xs text-base-600">
							<span class="font-mono uppercase tracking-wider text-[10px] text-base-500">
								Workflow
							</span>
							<input
								name="workflow"
								type="text"
								placeholder="deploy.yml"
								required
								class="h-9 rounded-md border border-base-200 bg-white px-3 font-mono text-xs text-base-900 focus:border-base-900 focus:outline-2 focus:outline-offset-2 focus:outline-base-900"
							/>
						</label>
						<label class="flex flex-col gap-1 text-xs text-base-600">
							<span class="font-mono uppercase tracking-wider text-[10px] text-base-500">
								Ref
							</span>
							<input
								name="ref"
								type="text"
								placeholder="main"
								required
								class="h-9 rounded-md border border-base-200 bg-white px-3 font-mono text-xs text-base-900 focus:border-base-900 focus:outline-2 focus:outline-offset-2 focus:outline-base-900"
							/>
						</label>
					</div>
					<Button size="sm" variant="default" type="submit">
						Trigger workflow
					</Button>
				</form>

				<div class="flex flex-col gap-3">
					<form method="post" action={`/api/projects/${slug}/deploy/approve`}>
						<Button size="sm" variant="accent" type="submit" class="w-full">
							Approve production deploy
						</Button>
					</form>
					<form
						method="post"
						action={`/api/projects/${slug}`}
						onsubmit="return confirm('Delete project? This cannot be undone.')"
					>
						<input type="hidden" name="_method" value="delete" />
						<Button size="sm" variant="danger" type="submit" class="w-full">
							Delete project
						</Button>
					</form>
					<form
						method="post"
						action={`/api/vps/${slug}/destroy`}
						onsubmit="return confirm('Destroy VPS? This will delete the Hetzner server.')"
					>
						<Button size="sm" variant="danger" type="submit" class="w-full">
							Destroy Hetzner VPS
						</Button>
					</form>
				</div>
			</div>
		</div>
	</section>

	<section class="mt-10 space-y-6">
		<SectionHeader kicker="Host" title="VPS metrics" />
		<div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
			<StatCard label="CPU" value="—" hint="15 min avg" />
			<StatCard label="Memory" value="—" hint="Resident" />
			<StatCard label="Disk" value="—" hint="Root volume" />
			<StatCard label="Uptime" value="—" hint="systemd reported" />
		</div>
	</section>

	<section class="mt-10 grid grid-cols-1 gap-6 lg:grid-cols-2">
		<article class="rounded-2xl border border-base-100 bg-white p-6 shadow-subtle">
			<SectionHeader kicker="Cloudflare" title="Pages + Workers" />
			<p class="mt-4 font-mono text-xs text-base-500">
				Wrangler bridge pending.
			</p>
		</article>

		<article class="rounded-2xl border border-base-100 bg-white p-6 shadow-subtle">
			<SectionHeader kicker="GitHub" title="Recent workflow runs" />
			<p class="mt-4 font-mono text-xs text-base-500">
				GitHub App wiring pending.
			</p>
		</article>
	</section>

	<section class="mt-10 space-y-6">
		<SectionHeader kicker="Observability" title="Live logs" />
		<pre
			class="max-h-80 overflow-auto rounded-2xl border border-base-100 bg-base-950 p-5 font-mono text-xs text-base-200"
		>
			<code>// logs stream placeholder</code>
		</pre>
	</section>
</DashboardLayout>
