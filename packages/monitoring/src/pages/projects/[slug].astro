---
import BaseLayout from '@/layouts/BaseLayout.astro'
import StatusBadge from '@/components/StatusBadge.astro'

export const prerender = false

const { slug } = Astro.params

if (!slug) {
	return Astro.redirect('/')
}
---

<BaseLayout title={`Project · ${slug}`}>
	<header class="proj-head">
		<div>
			<p class="crumb">
				<a href="/">← Back to projects</a>
			</p>
			<h1>{slug}</h1>
		</div>
		<StatusBadge status="unknown" />
	</header>

	<section class="actions">
		<h2>Actions</h2>
		<div class="action-row">
			<form method="post" action={`/api/projects/${slug}/workflows/dispatch`}>
				<label>
					Workflow
					<input name="workflow" type="text" placeholder="deploy.yml" required />
				</label>
				<label>
					Ref
					<input name="ref" type="text" placeholder="main" required />
				</label>
				<button type="submit">Trigger workflow</button>
			</form>

			<form method="post" action={`/api/projects/${slug}/deploy/approve`}>
				<button type="submit" class="btn-primary">Approve prod deploy</button>
			</form>

			<form
				method="post"
				action={`/api/projects/${slug}`}
				data-danger
				onsubmit="return confirm('Delete project? This cannot be undone.')"
			>
				<input type="hidden" name="_method" value="delete" />
				<button type="submit" class="btn-danger">Delete project</button>
			</form>

			<form
				method="post"
				action={`/api/vps/${slug}/destroy`}
				data-danger
				onsubmit="return confirm('Destroy VPS? This will delete the Hetzner server.')"
			>
				<button type="submit" class="btn-danger">Destroy VPS</button>
			</form>
		</div>
	</section>

	<section class="panels">
		<article class="panel">
			<h3>VPS metrics</h3>
			<p class="hint">CPU, memory, disk, uptime — wired to the VPS metrics endpoint.</p>
			<div class="metric-grid">
				<div class="metric"><span>CPU</span><strong>—</strong></div>
				<div class="metric"><span>Memory</span><strong>—</strong></div>
				<div class="metric"><span>Disk</span><strong>—</strong></div>
				<div class="metric"><span>Uptime</span><strong>—</strong></div>
			</div>
		</article>

		<article class="panel">
			<h3>Cloudflare Pages</h3>
			<p class="hint">Deployments, analytics, and Workers stats via wrangler.</p>
			<p class="empty">No data yet.</p>
		</article>

		<article class="panel panel-wide">
			<h3>Logs</h3>
			<p class="hint">Live journald + docker logs tailing.</p>
			<pre class="log-view">// logs stream placeholder</pre>
		</article>
	</section>
</BaseLayout>

<style>
	.proj-head {
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
		gap: var(--space-4);
		margin-bottom: var(--space-6);
	}

	.crumb {
		margin: 0 0 var(--space-2);
		font-size: 0.85rem;
	}

	.crumb a {
		color: var(--color-text-muted);
	}

	h1 {
		font-size: 1.8rem;
		font-family: var(--font-mono);
		font-weight: 600;
	}

	.actions {
		margin-bottom: var(--space-8);
	}

	.actions h2 {
		font-size: 1.1rem;
		margin-bottom: var(--space-3);
	}

	.action-row {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-3);
		align-items: flex-end;
		padding: var(--space-4) var(--space-6);
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
	}

	form {
		display: flex;
		gap: var(--space-3);
		align-items: flex-end;
	}

	label {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		font-size: 0.8rem;
		color: var(--color-text-muted);
	}

	input {
		padding: 0.45rem 0.6rem;
		background: var(--color-surface-2);
		color: var(--color-text);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		font-family: var(--font-mono);
		font-size: 0.85rem;
	}

	input:focus {
		outline: 2px solid var(--color-primary);
		outline-offset: 1px;
	}

	button {
		padding: 0.55rem 0.9rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		background: var(--color-surface-2);
		color: var(--color-text);
		cursor: pointer;
		font-weight: 500;
	}

	.btn-primary {
		background: var(--color-primary);
		border-color: var(--color-primary);
		color: #fff;
	}

	.btn-primary:hover {
		background: var(--color-primary-hover);
	}

	.btn-danger {
		background: transparent;
		border-color: var(--color-danger);
		color: var(--color-danger);
	}

	.btn-danger:hover {
		background: rgba(239, 68, 68, 0.08);
	}

	.panels {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: var(--space-4);
	}

	.panel {
		padding: var(--space-4) var(--space-6);
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
	}

	.panel-wide {
		grid-column: 1 / -1;
	}

	.panel h3 {
		font-size: 1rem;
		margin-bottom: var(--space-2);
	}

	.hint {
		margin: 0 0 var(--space-3);
		font-size: 0.85rem;
		color: var(--color-text-muted);
	}

	.empty {
		margin: 0;
		font-family: var(--font-mono);
		color: var(--color-text-muted);
	}

	.metric-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: var(--space-3);
	}

	.metric {
		display: flex;
		justify-content: space-between;
		padding: var(--space-3);
		background: var(--color-surface-2);
		border-radius: var(--radius-sm);
	}

	.metric span {
		color: var(--color-text-muted);
		font-size: 0.8rem;
	}

	.metric strong {
		font-family: var(--font-mono);
	}

	.log-view {
		margin: 0;
		padding: var(--space-3);
		background: #060914;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		color: var(--color-text-muted);
		font-size: 0.8rem;
		max-height: 320px;
		overflow: auto;
	}
</style>
